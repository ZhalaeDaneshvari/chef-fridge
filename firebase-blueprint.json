{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "likes": { "type": "array", "items": { "type": "string" } },
            "dislikes": { "type": "array", "items": { "type": "string" } },
            "dietaryRestrictions": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["email"]
    },
    "FridgeItem": {
      "title": "Fridge Item",
      "description": "An item currently in the user's refrigerator.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "addedAt"]
    },
    "Recipe": {
      "title": "Saved Recipe",
      "description": "A recipe generated by AI and saved by the user.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "string" },
        "nutrition": {
          "type": "object",
          "properties": {
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fat": { "type": "number" }
          }
        },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ingredients", "instructions", "savedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and preferences."
    },
    "/users/{userId}/fridgeItems/{itemId}": {
      "schema": "FridgeItem",
      "description": "Items in the user's fridge."
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "User's saved recipes."
    }
  }
}
